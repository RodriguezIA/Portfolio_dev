---
import type { Lang } from "../i18n/ui";

interface Props {
  title: string;
  lang: Lang;
}

const { title, lang } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <title>{title} | Software Developer</title>
    <meta
      name="description"
      content="Edgar Alan Rodriguez Amador - Software Developer building interactive and seamless digital experiences with cutting-edge frontend development."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://edgardev.com.mx/" />

    <!-- Alternate language links for SEO -->
    <link rel="alternate" hreflang="en" href="https://edgardev.com.mx/" />
    <link rel="alternate" hreflang="es" href="https://edgardev.com.mx/es/" />
    <link rel="alternate" hreflang="x-default" href="https://edgardev.com.mx/" />

    <link
      rel="preload"
      href="/fonts/montserrat-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <meta
      property="og:title"
      content="Edgar Alan Rodriguez Amador | Software Developer"
    />
    <meta
      property="og:description"
      content="Portfolio of Edgar Alan Rodriguez Amador, Software Developer specializing in frontend and interactive experiences."
    />
    <meta property="og:url" content="https://edgardev.com.mx" />
    <meta property="og:type" content="website" />
    <meta
      property="og:site_name"
      content="Edgar Alan Rodriguez Amador Portfolio"
    />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Edgar Alan Rodriguez Amador",
        "alternateName": "Edgar Rodriguez",
        "url": "https://edgardev.com.mx",
        "sameAs": [
          "https://github.com/RodriguezIA",
          "https://www.linkedin.com/in/edgar-alan-rodriguez-amador-3745b8148"
        ],
        "jobTitle": "Software Developer",
        "description": "Software Developer building interactive and seamless digital experiences."
      }
    </script>

    <!-- Language detection & auto-redirect (runs before render to avoid flash) -->
    <script is:inline>
      (function () {
        var SPANISH_COUNTRIES = [
          "MX","ES","AR","CO","CL","PE","VE","EC","GT","CU","BO","DO",
          "HN","PY","SV","NI","CR","PA","UY","GQ","PR",
        ];
        var STORAGE_KEY = "preferred-lang";

        // Only auto-redirect on the home pages — never on detail pages
        var path = window.location.pathname;
        if (path !== "/" && path !== "/es" && path !== "/es/") return;

        function redirect(lang) {
          var isEs = window.location.pathname.startsWith("/es");
          if (lang === "es" && !isEs) {
            window.location.replace("/es/");
          } else if (lang === "en" && isEs) {
            window.location.replace("/");
          }
        }

        // 1. Respect stored preference
        var stored = localStorage.getItem(STORAGE_KEY);
        if (stored === "en" || stored === "es") {
          redirect(stored);
          return;
        }

        // 2. First visit — check browser language
        var browserLang = (navigator.language || "").toLowerCase();
        if (browserLang.startsWith("es")) {
          localStorage.setItem(STORAGE_KEY, "es");
          redirect("es");
          return;
        }

        // 3. Fallback — IP-based country detection (async, no flash since 'en' is default)
        fetch("https://ip-api.com/json/?fields=countryCode")
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var detectedLang = SPANISH_COUNTRIES.includes(data.countryCode) ? "es" : "en";
            localStorage.setItem(STORAGE_KEY, detectedLang);
            redirect(detectedLang);
          })
          .catch(function () {
            localStorage.setItem(STORAGE_KEY, "en");
          });
      })();
    </script>
  </head>
  <body class="bg-[--background] overflow-x-hidden">
    <div id="cursor-dot" aria-hidden="true"></div>
    <div id="cursor-ring" aria-hidden="true"></div>
    <slot name="nav" />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </div>
  </body>
</html>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollSmoother } from "gsap/ScrollSmoother";

  gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reduced) {
    const smoother = ScrollSmoother.create({
      wrapper: "#smooth-wrapper",
      content: "#smooth-content",
      smooth: 1.2,
      effects: true,
      smoothTouch: 0.1,
    });

    // In-page anchors scroll through the smoother
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      a.addEventListener("click", (e) => {
        const target = document.querySelector(a.getAttribute("href") || "");
        if (target) {
          e.preventDefault();
          smoother.scrollTo(target, true, "top 80px");
        }
      });
    });

    // Reveals via IntersectionObserver — independent of ScrollSmoother's
    // transformed content, so elements can never get stuck hidden.
    const revealIO = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          revealIO.unobserve(el);
          if (el.hasAttribute("data-animate-group")) {
            gsap.to(el.children, {
              y: 0,
              autoAlpha: 1,
              duration: 0.85,
              ease: "power3.out",
              stagger: 0.12,
            });
          } else {
            gsap.to(el, { y: 0, autoAlpha: 1, duration: 1, ease: "power3.out" });
          }
        });
      },
      { rootMargin: "0px 0px -10% 0px" }
    );

    gsap.utils.toArray<HTMLElement>("[data-animate]").forEach((el) => {
      gsap.set(el, { y: 48, autoAlpha: 0 });
      revealIO.observe(el);
    });
    gsap.utils.toArray<HTMLElement>("[data-animate-group]").forEach((group) => {
      gsap.set(group.children, { y: 40, autoAlpha: 0 });
      revealIO.observe(group);
    });

    // Recalculate trigger positions once everything (images, 3D, fonts) loaded
    window.addEventListener("load", () => ScrollTrigger.refresh());

    // Scroll parallax: data-parallax="0.25" → element drifts as you scroll
    gsap.utils.toArray<HTMLElement>("[data-parallax]").forEach((el) => {
      const speed = parseFloat(el.dataset.parallax || "0.2");
      gsap.to(el, {
        yPercent: speed * 100,
        ease: "none",
        scrollTrigger: {
          trigger: el.parentElement ?? el,
          start: "top bottom",
          end: "bottom top",
          scrub: 1,
        },
      });
    });

    // Hero entrance (runs on load, no scroll needed)
    const heroItems = document.querySelectorAll("[data-hero-item]");
    if (heroItems.length) {
      gsap.from(heroItems, {
        y: 36,
        autoAlpha: 0,
        duration: 1.1,
        ease: "power3.out",
        stagger: 0.14,
        delay: 0.15,
      });
    }

    // Custom cursor (desktop fine pointers only)
    const dot = document.getElementById("cursor-dot");
    const ring = document.getElementById("cursor-ring");
    if (dot && ring && window.matchMedia("(pointer: fine)").matches) {
      document.documentElement.classList.add("has-custom-cursor");
      const dotX = gsap.quickTo(dot, "x", { duration: 0.08, ease: "power2.out" });
      const dotY = gsap.quickTo(dot, "y", { duration: 0.08, ease: "power2.out" });
      const ringX = gsap.quickTo(ring, "x", { duration: 0.45, ease: "power3.out" });
      const ringY = gsap.quickTo(ring, "y", { duration: 0.45, ease: "power3.out" });

      window.addEventListener(
        "mousemove",
        (e) => {
          dotX(e.clientX);
          dotY(e.clientY);
          ringX(e.clientX);
          ringY(e.clientY);
        },
        { passive: true }
      );

      // Grow the ring over interactive elements
      document.addEventListener("mouseover", (e) => {
        const interactive = (e.target as HTMLElement).closest("a, button, [role='button'], input, textarea");
        gsap.to(ring, { scale: interactive ? 2.2 : 1, duration: 0.3, ease: "power2.out" });
        gsap.to(dot, { scale: interactive ? 0.4 : 1, duration: 0.3 });
      });
    }
  }
</script>

<style is:global>
  @font-face {
    font-family: "Montserrat Variable";
    src: url("/fonts/montserrat-latin-wght-normal.woff2")
      format("woff2-variations");
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --background: #0d0c0a;
    --sec: #d97757;
    --sec-soft: #e8956f;
    --amber: #e3b341;
    --cream: #f0eee6;
    --white: #e6e3dd;
    --white-icon: #f0eee698;
    --white-icon-tr: #f0eee610;
  }

  * {
    font-family:
      "Montserrat Variable",
      -apple-system,
      system-ui,
      sans-serif;
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  *::selection {
    background-color: var(--sec);
    color: var(--background);
  }

  ::-webkit-scrollbar {
    width: 15px;
  }

  ::-webkit-scrollbar-track {
    background: var(--container);
    border-radius: 30px;
  }

  ::-webkit-scrollbar-thumb {
    background: var(--background);
    border-radius: 10px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--sec);
  }

  * {
    scrollbar-width: thin;
    scrollbar-color: var(--line) var(--container);
  }

  /* ---------- Custom cursor ---------- */
  #cursor-dot,
  #cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    border-radius: 9999px;
    transform: translate(-100px, -100px);
    display: none;
  }
  #cursor-dot {
    width: 8px;
    height: 8px;
    margin: -4px 0 0 -4px;
    background: var(--sec);
  }
  #cursor-ring {
    width: 36px;
    height: 36px;
    margin: -18px 0 0 -18px;
    border: 1.5px solid var(--sec);
    opacity: 0.55;
  }
  .has-custom-cursor #cursor-dot,
  .has-custom-cursor #cursor-ring {
    display: block;
  }
</style>
