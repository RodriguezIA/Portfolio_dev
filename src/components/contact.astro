---
import ChatBot from "../React/ChatBot.tsx";
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="w-full py-16 border-t border-[#ffffff10]">
  <div class="max-w-5xl xl:max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">
    <div data-animate>
      <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">{t("contact.eyebrow")}</h2>
      <h3 class="text-4xl md:text-5xl font-medium text-[var(--white)] mb-8">
        {t("contact.title")}
      </h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
      <!-- Izquierda: terminal estilo Omarchy -->
      <div
        class="wm-window flex flex-col rounded-lg border border-[#ffffff14] bg-[#121110] overflow-hidden transition-all duration-300"
        data-animate
      >
        <!-- Barra de título -->
        <div class="flex items-center gap-2.5 px-3.5 py-2 bg-[#1a1815] border-b border-[#ffffff0d] font-mono text-[11px]">
          <span class="flex gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-[#c45f3c]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#e3b341]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#7fb069]"></span>
          </span>
          <span class="text-[var(--white-icon)]">edgar@dev: ~/contact</span>
          <span class="ml-auto text-[var(--white-icon)] opacity-60" id="contact-clock"></span>
        </div>

        <!-- Cuerpo del terminal -->
        <div class="flex-1 p-5 font-mono text-sm leading-7 text-[var(--white-icon)]">
          <p>
            <span class="text-[#7fb069]">edgar@dev</span><span class="opacity-60">:</span><span class="text-[var(--sec)]">~</span><span class="opacity-60">$</span>
            <span class="terminal-typed text-[var(--white)]" data-text="whoami --contact"></span><span class="terminal-caret">▍</span>
          </p>

          <div class="terminal-output opacity-0 mt-2 space-y-1.5">
            <p><span class="text-[var(--sec)]">name</span><span class="opacity-50">:</span> Edgar Alan Rodriguez Amador</p>
            <p><span class="text-[var(--sec)]">role</span><span class="opacity-50">:</span> {t("hero.role")}</p>
            <p>
              <span class="text-[var(--sec)]">email</span><span class="opacity-50">:</span>
              <span class="text-[var(--white)]" id="contact-email">edgaralanra@gmail.com</span>
            </p>
            <p><span class="text-[var(--sec)]">location</span><span class="opacity-50">:</span> Monterrey, Nuevo León, MX</p>
            <p>
              <span class="text-[var(--sec)]">status</span><span class="opacity-50">:</span>
              <span class="text-[#7fb069]">● {t("contact.openToWork")}</span>
            </p>
            <p class="pt-1">
              <span class="text-[var(--sec)]">links</span><span class="opacity-50">:</span>
              <a href="https://github.com/RodriguezIA" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted underline-offset-4 hover:text-[var(--sec)] transition-colors">github</a>
              <span class="opacity-40">·</span>
              <a href="http://www.linkedin.com/in/edgar-alan-rodriguez-amador-3745b8148" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted underline-offset-4 hover:text-[var(--sec)] transition-colors">linkedin</a>
            </p>
          </div>

          <!-- Acciones -->
          <div class="terminal-output opacity-0 flex flex-wrap gap-3 mt-6">
            <button
              id="copy-email"
              data-copied={t("contact.copied")}
              class="inline-flex items-center gap-2 px-4 py-2.5 rounded bg-[var(--sec)] text-[#1a0f08] font-semibold text-xs hover:bg-[var(--sec-soft)] transition-colors cursor-pointer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                <path d="M7 4V2H17V4H20.0066C20.5552 4 21 4.44495 21 4.9934V21.0066C21 21.5552 20.5551 22 20.0066 22H3.9934C3.44476 22 3 21.5551 3 21.0066V4.9934C3 4.44476 3.44495 4 3.9934 4H7ZM7 6H5V20H19V6H17V8H7V6ZM9 4V6H15V4H9Z"></path>
              </svg>
              <span data-copy-label>{t("contact.copy")}</span>
            </button>
            <a
              href="https://mail.google.com/mail/?view=cm&fs=1&to=edgaralanra@gmail.com&su=Hey%20Edgar!"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2.5 rounded border border-[var(--white-icon-tr)] text-[var(--white-icon)] text-xs font-semibold hover:border-[var(--sec)] hover:text-[var(--sec)] transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                <path d="m18.73 5.41l-1.28 1L12 10.46L6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64"></path>
              </svg>
              {t("hero.cta2")}
            </a>
          </div>
        </div>
      </div>

      <!-- Derecha: chatbot (ventana hermana) -->
      <div data-animate>
        <ChatBot client:only="react" lang={lang} />
      </div>
    </div>
  </div>
</section>

<style>
  .wm-window:hover {
    border-color: var(--sec);
    box-shadow: 0 0 0 1px var(--sec), 0 8px 40px -12px rgba(217, 119, 87, 0.35);
  }
  .terminal-caret {
    animation: caret-blink 1s steps(1) infinite;
    color: var(--sec);
  }
  @keyframes caret-blink {
    50% { opacity: 0; }
  }
</style>

<script>
  import { gsap } from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Reloj local (Monterrey es la zona del visitante objetivo; usamos la del navegador)
  const clock = document.getElementById("contact-clock");
  const tick = () => {
    if (!clock) return;
    clock.textContent = new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
  };
  tick();
  setInterval(tick, 30_000);

  // Tipeo del comando cuando la sección entra en viewport
  const typed = document.querySelector<HTMLElement>(".terminal-typed");
  const outputs = document.querySelectorAll<HTMLElement>(".terminal-output");

  if (typed) {
    const text = typed.dataset.text || "";
    const reveal = () => {
      if (reduced) {
        typed.textContent = text;
        outputs.forEach((o) => (o.style.opacity = "1"));
        return;
      }
      const chars = { i: 0 };
      gsap.to(chars, {
        i: text.length,
        duration: text.length * 0.06,
        ease: "none",
        onUpdate: () => (typed.textContent = text.slice(0, Math.round(chars.i))),
        onComplete: () => {
          gsap.to(outputs, { opacity: 1, y: 0, duration: 0.6, stagger: 0.25, ease: "power2.out" });
        },
      });
      gsap.set(outputs, { y: 10 });
    };

    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          io.disconnect();
          reveal();
        }
      },
      { threshold: 0.4 }
    );
    io.observe(typed);
  }

  // Copiar correo
  const copyBtn = document.getElementById("copy-email");
  const copyLabel = copyBtn?.querySelector("[data-copy-label]");
  const original = copyLabel?.textContent || "";
  copyBtn?.addEventListener("click", async () => {
    const email = document.getElementById("contact-email")?.textContent?.trim() || "";
    try {
      await navigator.clipboard.writeText(email);
      if (copyLabel) {
        copyLabel.textContent = copyBtn.dataset.copied || "✓";
        setTimeout(() => (copyLabel.textContent = original), 2000);
      }
    } catch {
      // Clipboard no disponible — abrir mailto como fallback
      window.location.href = `mailto:${email}`;
    }
  });
</script>
