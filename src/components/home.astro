---
import LogoWall from "../components/logoWall.astro";
import Cozy3d from "../components/cozy3d.astro";
import SkillsList from "../React/SkillsList.tsx";
import { experience } from "../data/experience";
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = lang === "es" ? "/es" : "";
const nameLines = ["Edgar", "Rodriguez"];
const words = [t("hero.words.0"), t("hero.words.1"), t("hero.words.2"), t("hero.words.3")];
---

<section class="text-[var(--white)]" id="home">
  <!-- ============ HERO (full-bleed, sin marcos) ============ -->
  <div class="hero relative min-h-svh flex flex-col justify-center overflow-hidden">
    <!-- Fondo: glows cálidos + grano -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="hero-glow absolute -top-[20%] -right-[10%] w-[60vw] h-[60vw] rounded-full opacity-[0.16]" style="background: radial-gradient(circle, var(--sec) 0%, transparent 60%);"></div>
      <div class="hero-glow-2 absolute -bottom-[30%] -left-[15%] w-[55vw] h-[55vw] rounded-full opacity-[0.10]" style="background: radial-gradient(circle, var(--amber) 0%, transparent 60%);"></div>
      <div class="hero-grain absolute inset-0"></div>
    </div>

    <!-- Marca de agua gigante -->
    <div class="hero-watermark absolute top-1/2 left-0 -translate-y-1/2 whitespace-nowrap font-black uppercase -z-10 pointer-events-none" data-parallax="-0.1">
      {t("hero.role")} · {t("hero.role")}
    </div>

    <div class="relative w-full max-w-[1560px] mx-auto px-6 sm:px-10 lg:px-16 grid lg:grid-cols-[1.2fr_0.9fr] gap-6 lg:gap-8 items-center pt-24 pb-20 lg:py-0">
      <!-- Columna izquierda -->
      <div class="space-y-6 lg:space-y-8">
        <!-- Pill de disponibilidad -->
        <div class="hero-fade inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-[var(--white-icon-tr)] bg-[#1414149c] backdrop-blur-sm text-sm text-[var(--white-icon)]">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#7fb069] opacity-60"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[#7fb069]"></span>
          </span>
          {t("hero.available")}
        </div>

        <!-- Nombre gigante con reveal por caracteres -->
        <h1 class="hero-name font-black uppercase leading-[0.92] tracking-[-0.02em]">
          {nameLines.map((line, li) => (
            <span class="block overflow-hidden pb-[0.08em] -mb-[0.08em]">
              <span class="hero-line inline-block">
                {line.split("").map((c) => (
                  <span class={`hero-char inline-block will-change-transform ${li === 1 ? "hero-char-accent" : ""}`}>{c}</span>
                ))}
              </span>
            </span>
          ))}
        </h1>

        <!-- Rol + palabra rotativa -->
        <div class="hero-fade flex flex-wrap items-baseline gap-x-3 text-xl md:text-3xl font-medium">
          <span class="text-[var(--white-icon)]">{t("hero.role")}</span>
          <span class="text-[var(--white-icon)] hidden sm:inline">·</span>
          <span class="word-rotator relative inline-block overflow-hidden align-baseline h-[1.35em] min-w-[7ch]">
            {words.map((w, i) => (
              <span class={`word absolute left-0 top-0 text-[var(--sec)] font-semibold whitespace-nowrap ${i === 0 ? "" : "opacity-0"}`}>{w}</span>
            ))}
          </span>
        </div>

        <!-- Descripción -->
        <p class="hero-fade text-base md:text-lg text-[var(--white-icon)] max-w-xl leading-relaxed">
          {t("hero.desc")}
          <span class="text-[var(--sec)] shiny-sec font-semibold">{t("hero.desc.highlight")}</span>
          {t("hero.desc.end")}
        </p>

        <!-- CTAs + redes -->
        <div class="hero-fade flex flex-wrap items-center gap-4 pt-2">
          <a
            href="#projects"
            class="magnetic group inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[var(--sec)] text-[#1a0f08] font-semibold text-base hover:bg-[var(--sec-soft)] transition-colors duration-300"
          >
            {t("hero.cta")}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5 transition-transform duration-300 group-hover:translate-x-1">
              <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"></path>
            </svg>
          </a>
          <a
            href="#contact"
            class="magnetic inline-flex items-center px-7 py-3.5 rounded-full border border-[var(--white-icon-tr)] text-[var(--white)] font-medium hover:border-[var(--sec)] hover:text-[var(--sec)] transition-colors duration-300"
          >
            {t("hero.cta2")}
          </a>

          <div class="flex items-center gap-2 sm:ml-2">
            <a
              target="_blank"
              href="https://github.com/RodriguezIA"
              aria-label="GitHub"
              class="magnetic text-[var(--white-icon)] hover:text-white transition-colors duration-300 p-3"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7">
                <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"></path>
              </svg>
            </a>
            <a
              target="_blank"
              href="http://www.linkedin.com/in/edgar-alan-rodriguez-amador-3745b8148"
              aria-label="LinkedIn"
              class="magnetic text-[var(--white-icon)] hover:text-white transition-colors duration-300 p-3"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7">
                <path d="M18.3362 18.339H15.6707V14.1622C15.6707 13.1662 15.6505 11.8845 14.2817 11.8845C12.892 11.8845 12.6797 12.9683 12.6797 14.0887V18.339H10.0142V9.75H12.5747V10.9207H12.6092C12.967 10.2457 13.837 9.53325 15.1367 9.53325C17.8375 9.53325 18.337 11.3108 18.337 13.6245V18.339H18.3362ZM7.00373 8.57475C6.14573 8.57475 5.45648 7.88025 5.45648 7.026C5.45648 6.1725 6.14648 5.47875 7.00373 5.47875C7.85873 5.47875 8.55173 6.1725 8.55173 7.026C8.55173 7.88025 7.85798 8.57475 7.00373 8.57475ZM8.34023 18.339H5.66723V9.75H8.34023V18.339ZM19.6697 3H4.32923C3.59498 3 3.00098 3.5805 3.00098 4.29675V19.7033C3.00098 20.4202 3.59498 21 4.32923 21H19.6675C20.401 21 21.001 20.4202 21.001 19.7033V4.29675C21.001 3.5805 20.401 3 19.6675 3H19.6697Z"></path>
              </svg>
            </a>
            <a
              target="_blank"
              href="https://mail.google.com/mail/?view=cm&fs=1&to=edgaralanra@gmail.com&su=Hey%20Edgar!"
              aria-label="Email"
              class="magnetic text-[var(--white-icon)] hover:text-white transition-colors duration-300 p-3"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7">
                <path d="m18.73 5.41l-1.28 1L12 10.46L6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Escena 3D (Three.js) -->
      <div class="hero-3d relative order-first lg:order-none lg:translate-x-12 xl:translate-x-20 lg:-mr-6 xl:-mr-10">
        <Cozy3d />
      </div>
    </div>

    <!-- Indicador de scroll + ubicación -->
    <div class="hero-fade absolute bottom-6 left-0 right-0 hidden md:flex items-end justify-between px-6 sm:px-10 lg:px-16 text-xs uppercase tracking-[0.25em] text-[var(--white-icon)]">
      <span>{t("hero.based")}</span>
      <span class="flex flex-col items-center gap-2">
        {t("hero.scroll")}
        <span class="scroll-line block w-[1px] h-10 bg-gradient-to-b from-[var(--sec)] to-transparent"></span>
      </span>
      <span>GitHub · LinkedIn</span>
    </div>
  </div>

  <!-- Carrusel de tecnologías (full-bleed) -->
  <div class="border-y border-[#ffffff08]" data-animate>
    <LogoWall />
  </div>

  <!-- ============ What I do + When ============ -->
  <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 pt-16 pb-14 flex flex-col lg:flex-row items-start gap-8 lg:gap-16">
    <div class="w-full lg:max-w-[420px]" data-animate>
      <SkillsList client:only="react" lang={lang} />
    </div>

    <!-- When? timeline -->
    <div class="text-left pt-3 md:pt-9 w-full lg:flex-1" data-animate>
      <h3 class="text-[var(--white)] text-3xl md:text-4xl font-semibold mb-4 md:mb-6">
        {t("when.title")}
      </h3>

      <div class="relative space-y-0 mt-4">
        <!-- Línea vertical -->
        <div class="absolute left-[11px] top-2 bottom-4 w-[2px] bg-[var(--white-icon-tr)]"></div>

        {experience.map((exp, i) => (
          <div class="relative pl-9 pb-5">
            <div
              class={`absolute left-0 top-[18px] w-[22px] h-[22px] rounded-full border-2 z-10 ${
                i === 0
                  ? "bg-[var(--sec)] border-[var(--background)]"
                  : i === 1
                  ? "bg-[#1414149c] border-[var(--sec)]"
                  : "bg-[#1414149c] border-[var(--white-icon-tr)]"
              }`}
            ></div>
            <a
              href={`${base}/experience/${exp.slug}/`}
              class="group block bg-[#1414149c] border border-[var(--white-icon-tr)] rounded-2xl p-4 hover:border-[var(--sec)] transition-all duration-300 hover:translate-x-1"
            >
              <div class="flex items-start justify-between gap-3">
                <div>
                  <span class={`text-xs font-semibold tracking-widest uppercase ${i === 0 ? "text-[var(--sec)]" : "text-[var(--white-icon)]"}`}>
                    {exp.period[lang]}
                  </span>
                  <h4 class="text-[var(--white)] text-base font-semibold mt-1">
                    {exp.role}
                  </h4>
                  <p class="text-[var(--white-icon)] text-sm mt-1">
                    {exp.company} · {exp.location[lang]}
                  </p>
                </div>
                <span class="flex items-center gap-1.5 text-xs text-[var(--white-icon)] opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap pt-1 group-hover:text-[var(--sec)]">
                  {t("exp.viewDetail")}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-3.5">
                    <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"></path>
                  </svg>
                </span>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style is:global>
  .hero-name {
    font-size: clamp(3rem, 8.2vw, 7.8rem);
    white-space: nowrap;
  }
  .hero-char-accent {
    color: var(--sec);
  }
  .hero-watermark {
    font-size: clamp(8rem, 22vw, 22rem);
    color: transparent;
    -webkit-text-stroke: 1.5px #f0eee612;
    letter-spacing: 0.02em;
  }
  .hero-grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.045;
  }
  .scroll-line {
    animation: scroll-pulse 2s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes scroll-pulse {
    0%, 100% { transform: scaleY(0.3); opacity: 0.4; }
    50% { transform: scaleY(1); opacity: 1; }
  }
  .shiny-sec {
    background: linear-gradient(135deg, #d97757 25%, #ffe9d6 50%, #d97757 75%);
    background-size: 400% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 3s linear infinite;
  }
  @keyframes shine {
    0% { background-position: 100% 50%; }
    30%, 70% { background-position: 0% 50%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-line { animation: none; }
  }
</style>

<script>
  import { gsap } from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const fine = window.matchMedia("(pointer: fine)").matches;

  if (!reduced) {
    // --- Reveal del nombre, caracter por caracter ---
    gsap.from(".hero-char", {
      yPercent: 118,
      rotation: 8,
      duration: 1.15,
      ease: "power4.out",
      stagger: 0.04,
      delay: 0.25,
    });

    // --- Fades del resto del hero ---
    gsap.from(".hero-fade", {
      y: 32,
      autoAlpha: 0,
      duration: 1,
      ease: "power3.out",
      stagger: 0.1,
      delay: 0.7,
    });

    // --- Glows respiran ---
    gsap.to(".hero-glow", { scale: 1.18, duration: 5, ease: "sine.inOut", yoyo: true, repeat: -1 });
    gsap.to(".hero-glow-2", { scale: 1.25, duration: 7, ease: "sine.inOut", yoyo: true, repeat: -1 });

    // --- Palabras rotativas ---
    const wordEls = gsap.utils.toArray<HTMLElement>(".word-rotator .word");
    if (wordEls.length > 1) {
      const tl = gsap.timeline({ repeat: -1, delay: 1.5 });
      wordEls.forEach((word, i) => {
        const next = wordEls[(i + 1) % wordEls.length];
        tl.to(word, { yPercent: -110, autoAlpha: 0, duration: 0.5, ease: "power2.in" }, `+=1.8`)
          .fromTo(next, { yPercent: 110, autoAlpha: 0 }, { yPercent: 0, autoAlpha: 1, duration: 0.5, ease: "power2.out" }, "<0.15");
      });
    }

    // --- Botones magnéticos ---
    if (fine) {
      document.querySelectorAll<HTMLElement>(".magnetic").forEach((el) => {
        const xTo = gsap.quickTo(el, "x", { duration: 0.4, ease: "power3.out" });
        const yTo = gsap.quickTo(el, "y", { duration: 0.4, ease: "power3.out" });
        el.addEventListener("mousemove", (e) => {
          const r = el.getBoundingClientRect();
          xTo((e.clientX - r.left - r.width / 2) * 0.35);
          yTo((e.clientY - r.top - r.height / 2) * 0.35);
        });
        el.addEventListener("mouseleave", () => {
          xTo(0);
          yTo(0);
        });
      });
    }
  }
</script>
