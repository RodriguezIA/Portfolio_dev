---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";
import { projects, noImageBgs, noImageGlow, type TilePosition } from "../data/projects";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const base = lang === "es" ? "/es" : "";

// Sort by priority so CSS grid auto-places correctly
const sorted = [...projects].sort((a, b) => a.priority - b.priority);

const getTileSpan = (priority: number): string =>
  priority === 1 ? "md:col-span-3 md:row-span-2" : "";

const getMobileHeight = (priority: number): string => {
  if (priority === 1) return "h-[300px]";
  if (priority === 2) return "h-[200px]";
  return "h-[180px]";
};

const getOverlay = (position: TilePosition): string => {
  if (position === "top")
    return "bg-gradient-to-b from-black/80 via-black/25 to-transparent";
  if (position === "center")
    return "bg-gradient-to-b from-black/50 via-black/20 to-black/55";
  return "bg-gradient-to-t from-black/88 via-black/40 to-transparent";
};

const getContentAlign = (position: TilePosition): string => {
  if (position === "top") return "justify-start pt-5";
  if (position === "center") return "justify-center";
  return "justify-end pb-5";
};
---

<section
  id="projects"
  class="py-12 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl xl:max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">
    <div data-animate>
      <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">{t("projects.eyebrow")}</h2>
      <h3 class="text-4xl md:text-5xl font-medium mb-8">{t("projects.title")}</h3>
    </div>

    <!-- Grid estilo tiling window manager (Omarchy) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-3 md:[grid-auto-rows:230px] xl:[grid-auto-rows:265px]" data-animate-group>
      {sorted.map((project, idx) => (
        <a
          href={`${base}/projects/${project.slug}/`}
          class={[
            "wm-window relative cursor-pointer group flex flex-col overflow-hidden rounded-lg",
            "border border-[#ffffff14] bg-[#121110]",
            "transition-all duration-300",
            getMobileHeight(project.priority),
            "sm:h-[230px] md:h-auto",
            getTileSpan(project.priority),
          ].join(" ")}
        >
          <!-- Barra de título de la "ventana" -->
          <div class="flex items-center gap-2.5 px-3.5 py-2 bg-[#1a1815] border-b border-[#ffffff0d] font-mono text-[11px] flex-shrink-0 z-10">
            <span class="flex gap-1.5 flex-shrink-0">
              <span class="w-2.5 h-2.5 rounded-full bg-[#c45f3c] opacity-80 group-hover:opacity-100 transition-opacity"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#e3b341] opacity-80 group-hover:opacity-100 transition-opacity"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#7fb069] opacity-80 group-hover:opacity-100 transition-opacity"></span>
            </span>
            <span class="truncate text-[var(--white-icon)] group-hover:text-[var(--sec)] transition-colors">
              ~/projects/{project.slug}
            </span>
            <span class="ml-auto flex-shrink-0 text-[10px] uppercase tracking-wider text-[var(--white-icon)] opacity-70">
              {project.status[lang]}
            </span>
          </div>

          <!-- Cuerpo de la ventana -->
          <div class="relative flex-1 overflow-hidden">
            {project.image ? (
              <img
                src={project.image}
                alt={project.title}
                class={[
                  "absolute inset-0 w-full h-full object-cover",
                  "transition-transform duration-500 group-hover:scale-[1.05]",
                  project.position === "top"
                    ? "object-top"
                    : project.position === "center"
                      ? "object-center"
                      : "object-bottom",
                ].join(" ")}
                loading="lazy"
              />
            ) : (
              <div class={`absolute inset-0 ${noImageBgs[idx % noImageBgs.length]}`}>
                <div
                  class="absolute inset-0 opacity-20"
                  style={`background-image: ${noImageGlow}`}
                />
                <span class="absolute inset-0 flex items-center justify-center font-mono text-[var(--white-icon)] opacity-30 text-4xl select-none">
                  {"</>"}
                </span>
              </div>
            )}

            <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent" />

            <!-- Contenido -->
            <div class="absolute inset-x-0 bottom-0 p-4">
              <h4
                class={[
                  "font-bold text-white leading-tight",
                  project.priority === 1 ? "text-2xl md:text-3xl" : "text-lg",
                ].join(" ")}
              >
                {project.title}
              </h4>
              <div class="flex flex-wrap gap-1.5 mt-2">
                {project.tech.slice(0, project.priority === 1 ? 5 : 3).map((tech) => (
                  <span class="px-2 py-0.5 text-[10px] font-mono rounded bg-black/60 border border-white/10 text-white/70 group-hover:border-[var(--sec)]/40 transition-colors">
                    {tech}
                  </span>
                ))}
              </div>
            </div>

            <!-- Flecha al hover -->
            <div class="absolute top-3 right-3 opacity-0 -translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
              <div class="size-8 flex items-center justify-center rounded bg-black/60 border border-[var(--sec)]/50 text-[var(--sec)]">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                  <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- More projects link -->
    <a
      target="_blank"
      rel="noopener noreferrer"
      href="https://github.com/RodriguezIA?tab=repositories"
      aria-label="GitHub"
      data-animate
      class="w-full flex items-center justify-center gap-2 mt-6 text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-3 rounded-full bg-[#1414149c] hover:bg-[var(--white-icon-tr)] hover:scale-105"
    >
      <span class="md:text-lg text-md">{t("projects.more")}</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
        <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z" />
      </svg>
    </a>
  </div>
</section>

<style>
  /* "Ventana enfocada" al estilo tiling WM: borde acento + glow */
  .wm-window:hover {
    border-color: var(--sec);
    box-shadow:
      0 0 0 1px var(--sec),
      0 8px 40px -12px rgba(217, 119, 87, 0.45);
    transform: translateY(-2px);
  }
</style>
